# ── TennisIQ MVP — Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values

# Anthropic API (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Whoop API (get from developer.whoop.com)
WHOOP_CLIENT_ID=your_whoop_client_id_here
WHOOP_CLIENT_SECRET=your_whoop_client_secret_here
WHOOP_ACCESS_TOKEN=your_whoop_access_token_here

# Terra API (get from tryterra.co — free tier)
TERRA_API_KEY=your_terra_api_key_here
TERRA_DEV_ID=your_terra_dev_id_here

# Database (Railway PostgreSQL or local)
DATABASE_URL=postgresql://user:password@localhost:5432/tennisiq

# App settings
SECRET_KEY=your_secret_key_for_jwt
APP_ENV=development
PORT=8000

# Email notifications (optional for MVP — use Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
